# Copie para .env e ajuste conforme a VPS.
# Porta no host (vinculada só ao localhost — use Nginx Proxy Manager na frente).
HTTP_PORT=8080

# Obrigatórios em produção. Gere uma vez e mantenha persistente no .env da VPS.
# Não regenere a cada deploy, senão a chave admin e os tokens CSRF em uso mudam.
ADMIN_API_KEY=troque-por-um-valor-gerado-com-openssl-rand-hex-32
CSRF_SECRET=troque-por-um-valor-gerado-com-openssl-rand-hex-32

# Caminho no host para GeoLite2-City.mmdb (opcional; descomente o volume no compose).
# GEO_DB_HOST_PATH=./data/geo/GeoLite2-City.mmdb
